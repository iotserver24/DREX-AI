{
  "name": "drex-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev renderer",
    "build:renderer": "next build renderer",
    "build:main": "bun build main/index.ts --outdir dist/main --target bun",
    "build": "bun run build:renderer && bun run build:main",
    "start": "bun run main/index.ts",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "drex-core": "file:../core",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "latest",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "electrobun": "latest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0"
  }
}
